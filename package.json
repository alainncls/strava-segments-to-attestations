{
  "name": "strava-segments-to-attestations",
  "version": "1.0.0",
  "private": true,
  "description": "Create Verax attestations for Strava segments you've completed",
  "keywords": [
    "strava",
    "verax",
    "attestation",
    "linea",
    "blockchain"
  ],
  "license": "MIT",
  "author": "alain.linea.eth",
  "type": "module",
  "scripts": {
    "build": "pnpm -r build",
    "clean": "pnpm -r clean && rm -rf node_modules",
    "dev": "pnpm -r --parallel run dev",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "preinstall": "node -e \"const execPath=process.env.npm_execpath||'';if(!process.env.PNPM_SCRIPT_SRC_DIR&&!/[\\\\/]pnpm(?:\\\\.cjs)?$/.test(execPath)){console.error('Use pnpm install for installation in this project.');process.exit(1)}\"",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "pnpm -r test",
    "test:e2e": "pnpm --filter @strava-attestations/frontend test:e2e",
    "test:coverage": "pnpm -r test:coverage"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "catalog:",
    "eslint": "catalog:",
    "eslint-config-prettier": "catalog:",
    "globals": "catalog:",
    "prettier": "catalog:",
    "prettier-plugin-solidity": "^2.3.1",
    "typescript": "catalog:",
    "typescript-eslint": "catalog:"
  },
  "packageManager": "pnpm@11.0.3",
  "engines": {
    "node": ">=24.14.1",
    "pnpm": ">=11.0.3"
  }
}
